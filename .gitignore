# Referencia:
# https://git-scm.com/docs/gitignore

# ------------------------------
# Dependencias
# ------------------------------
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# ------------------------------
# Build / ejecución
# ------------------------------
/.next/
/out/
/build/
/dist/

# ------------------------------
# Cobertura y reportes / Linters
# ------------------------------
/coverage
*.lcov
.nyc_output/
eslint_report.json
*_report.json


# ------------------------------
# Logs y depuración
# ------------------------------
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
lerna-debug.log*
*.log

# ------------------------------
# Variables de entorno
# ------------------------------
.env*
!.env.example
!.env*.example

# ------------------------------
# Vercel
# ------------------------------
.vercel

# ------------------------------
# TypeScript
# ------------------------------
*.tsbuildinfo
next-env.d.ts

# ------------------------------
# Sistema / editores
# ------------------------------
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json
.idea/

# ------------------------------
# Archivos sensibles
# ------------------------------
*.pem
*.key
*.crt
*.p12
*.cer

# ------------------------------
# Firebase / emuladores / exports locales
# ------------------------------
.firebase/
firestore-debug.log
ui-debug.log
*-debug.log
firebase-debug.log*
firebase-export-*

# ------------------------------
# Caché
# ------------------------------
.cache/
.parcel-cache/
.turbo/
tmp/
temp/

# ------------------------------
# Herramientas de IA, Asistentes, Skills y Reglas de Agente
# Se ignoran datos locales, sesiones, cachés, habilidades (skills)
# y archivos de reglas de desarrollo local.
# ------------------------------
.claude/
.cursor/
.cursor-tutor/
.cursorrules
.cursorrules.md
.windsurf/
.copilot/
.github/
.agent/
.agents/
.qwen/
.sixth/
.qodo/
.llm/
.ai/
.prompts/
.memory/
.memories/
.sessions/
.context/
.contexts/
.gemini/
skills/

# Archivos de configuración de agentes
AGENTS.md
AGENT.md
CLAUDE.md

# ------------------------------
# Scripts locales, Utilidades y Bóveda Obsidian
# ------------------------------
*.pid
*.seed
createAdmin.js
resetDatabase.js
resetCompleto.js
resetDataNoUsuarios.js
migrar-*.js
migrar-*.mjs
migrar-*.cjs
documentacion.txt
docs-obsidian
flujo-creacion-usuarios-primer-ingreso.txt


