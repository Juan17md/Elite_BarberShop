rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function isSuperadmin() {
      return isAuthenticated() &&
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "superadmin";
    }
    
    function isAdmin() {
      return isAuthenticated() && exists(/databases/(default)/documents/users/$(request.auth.uid)) && (
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "superadmin"
      );
    }
    
    function isBarber() {
      return isAuthenticated() && exists(/databases/(default)/documents/users/$(request.auth.uid)) && (
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "barber" ||
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "admin" ||
        get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == "superadmin"
      );
    }
    
    // Usuarios: solo superadmin escribe desde cliente, lectura para autenticados
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isSuperadmin();
      allow create: if isSuperadmin();
    }
    
    // Servicios
    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow write: if isBarber();
      allow create: if isBarber();
    }
    
    // Clientes
    match /clients/{clienteId} {
      allow read: if isAuthenticated();
      allow write: if isBarber();
      allow create: if isBarber();
    }
    
    // Reservas/Citas
    match /reservas/{reservaId} {
      allow read: if isAuthenticated();
      allow write: if isBarber();
      allow create: if isAuthenticated();
    }

    // Bloqueos de calendario
    match /blocked_times/{blockId} {
      allow read: if isAuthenticated();
      allow write: if isBarber();
      allow create: if isBarber();
    }
    
    // Inventario
    match /inventory/{productoId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
    
    // Transacciones y Actas
    match /transacciones/{actaId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isBarber();
      allow create: if isAdmin() || isBarber();
    }
    
    // Finanzas
    match /finances/{registroId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isBarber();
      allow update: if isAdmin() || (
        isBarber() &&
        resource.data.barberId == request.auth.uid &&
        request.resource.data.barberId == request.auth.uid
      );
      allow delete: if isAdmin();
    }

    // Banco (Billeteras de Barberos y Barbería)
    match /bank/{bankId} {
      allow read: if isOwner(bankId) || isAdmin() || (isBarber() && bankId == "barbershop");
      allow write: if isOwner(bankId) || isAdmin() || (isBarber() && bankId == "barbershop");
    }

    // Transacciones Bancarias
    match /bank_transactions/{registroId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || (isBarber() && (request.resource.data.userId == request.auth.uid || request.resource.data.userId == "barbershop"));
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // Objetivos
    match /objectives/{objId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || (isBarber() && request.resource.data.barberoId == request.auth.uid);
      allow update: if isAdmin() || (
        isBarber() &&
        "barberoId" in resource.data && resource.data.barberoId == request.auth.uid &&
        request.resource.data.barberoId == request.auth.uid
      );
      allow delete: if isAdmin() || (isBarber() && "barberoId" in resource.data && resource.data.barberoId == request.auth.uid);
    }

    // Configuraciones del sistema
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
