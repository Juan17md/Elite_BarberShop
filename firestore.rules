rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    function getUserDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }
    
    function userDocExists() {
      return getUserDoc().exists;
    }
    
    function getUserRole() {
      return getUserDoc().data.role;
    }
    
    function isSuperadmin() {
      return isAuthenticated() && userDocExists() && getUserRole() == "superadmin";
    }
    
    function isAdmin() {
      return isAuthenticated() && userDocExists() && (getUserRole() == "admin" || getUserRole() == "superadmin");
    }
    
    function isBarber() {
      return isAuthenticated() && userDocExists() && (getUserRole() == "barber" || getUserRole() == "admin" || getUserRole() == "superadmin");
    }
    
    // Usuarios: solo superadmin escribe desde cliente, lectura para autenticados
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isSuperadmin();
      allow create: if isSuperadmin();
    }
    
    // Servicios
    match /services/{serviceId} {
      allow read: if isAuthenticated();
      allow write: if isBarber();
      allow create: if isBarber();
    }
    
    // Clientes
    match /clients/{clienteId} {
      allow read: if isAuthenticated();
      allow write: if isBarber();
      allow create: if isBarber();
    }
    
    // Reservas/Citas
    match /reservas/{reservaId} {
      allow read: if isAuthenticated();
      allow write: if isBarber();
      allow create: if isAuthenticated();
    }

    // Bloqueos de calendario
    match /blocked_times/{blockId} {
      allow read: if isAuthenticated();
      allow write: if isBarber();
      allow create: if isBarber();
    }
    
    // Inventario
    match /inventory/{productoId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
      allow create: if isAdmin();
    }
    
    // Transacciones y Actas
    match /transacciones/{actaId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isBarber();
      allow create: if isAdmin() || isBarber();
    }
    
    // Finanzas
    match /finances/{registroId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || isBarber();
      allow create: if isAdmin() || isBarber();
    }

    // Banco (Billeteras de Barberos y Barbería)
    match /bank/{bankId} {
      allow read: if isOwner(bankId) || isAdmin() || (isBarber() && bankId == "barbershop");
      allow write: if isOwner(bankId) || isAdmin() || (isBarber() && bankId == "barbershop");
    }

    // Transacciones Bancarias
    match /bank_transactions/{registroId} {
      allow read: if isAuthenticated();
      allow create: if isAdmin() || isBarber() || (isAuthenticated() && request.resource.data.userId == request.auth.uid);
      allow write: if isAdmin();
    }

    // Objetivos
    match /objectives/{objId} {
      allow read: if isAdmin() || (isAuthenticated() && resource.data.barberoId == request.auth.uid);
      allow create: if isAdmin() || (isBarber() && request.resource.data.barberoId == request.auth.uid);
      allow update: if isAdmin() || (
        isBarber() &&
        resource.data.barberoId == request.auth.uid &&
        request.resource.data.barberoId == request.auth.uid
      );
      allow delete: if isAdmin() || (isBarber() && resource.data.barberoId == request.auth.uid);
    }

    // Configuraciones del sistema
    match /settings/{settingId} {
      allow read: if isAuthenticated();
      allow write: if isBarber();
    }
  }
}
